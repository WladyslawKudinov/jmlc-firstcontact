# --- Synthetic data generation ---
# Supported providers are OpenAI-compatible chat APIs: xai | openai.
# (Anthropic is NOT wired — its API isn't OpenAI-shaped; add a provider branch in
#  ml/llm.py if you need it.) Use whichever key matches your GEN_PROVIDER.
XAI_API_KEY=
OPENAI_API_KEY=

# Which provider + chat model to generate calls with.
#   GEN_PROVIDER: xai | openai
GEN_PROVIDER=xai
#   GEN_MODEL: set to a CHAT model you have access to, e.g.
#     xai: grok-2-latest   openai: gpt-4o-mini
GEN_MODEL=

# Optional: a SECOND model/temperature for the distribution-shift ("does it
# generalize?") held-out set. A *different* GEN_MODEL_OOD makes gen-B a genuine
# model-level shift, not just a temperature change.
GEN_MODEL_OOD=
GEN_TEMPERATURE_OOD=1.1
